# Built binaries (leading slash = root only, not cmd/centinela/ directory)
/centinela
/centinela-*

# Go test and benchmark artifacts
*.exe
*.test
*.out

# Dependency vendor directory (we use go modules)
vendor/

# Per-feature git worktrees (workflow.use_worktrees)
.worktrees/

# Playwright MCP scratch (page snapshots, console logs) + local screenshots
.playwright-mcp/
landing-*.png
landing-*.jpeg

# Local private notes — not committed
ECOSYSTEM.md

# Local governance telemetry — local-only in this repo (feature contract for other projects is git-tracked)
.workflow/telemetry/

# `centinela analyze` generated inventory — derived from the code, regenerated on demand
.workflow/analysis.json

# Per-feature evidence is machine plumbing — generated and validated locally by
# `centinela complete`, never read after a feature merges. Keep the readable
# -<role>.md companions (reviewer + LLM knowledge base) committed; drop the
# machine-only JSON and the never-deleted advisory .lock files.
.workflow/*.json
.workflow/*.lock
# ...EXCEPT these top-level JSONs are durable project state, NOT per-feature
# evidence — they MUST stay tracked. The roadmap bootstrap artifacts gate
# greenfield start (rehydration + senior-PM analysis + quality scoring) and the
# audit baseline is the committed ratchet snapshot. Gitignoring them blocks the
# workflow, so any new durable-state .workflow/*.json belongs on this allow-list.
!.workflow/roadmap.json
!.workflow/roadmap-analysis.json
!.workflow/roadmap-quality.json
!.workflow/audit-baseline.json

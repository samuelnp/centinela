# Built binaries (leading slash = root only, not cmd/centinela/ directory)
/centinela
/centinela-*

# Go test and benchmark artifacts
*.exe
*.test
*.out

# Dependency vendor directory (we use go modules)
vendor/

# Per-feature git worktrees (workflow.use_worktrees)
.worktrees/

# Playwright MCP scratch (page snapshots, console logs) + local screenshots
.playwright-mcp/
landing-*.png
landing-*.jpeg

# Local private notes — not committed
ECOSYSTEM.md

# Local governance telemetry — local-only in this repo (feature contract for other projects is git-tracked)
.workflow/telemetry/

# `centinela analyze` generated inventory — derived from the code, regenerated on demand
.workflow/analysis.json

# Per-feature ROLE evidence is machine plumbing — generated and validated
# locally by `centinela complete`, inert after a feature merges. Ignore those
# JSONs plus the never-deleted advisory .lock files. Everything ELSE under
# .workflow/ is durable project state and MUST stay tracked: the per-feature
# root <feature>.json (the completion ledger FeatureStatus reads to show the
# roadmap's done/ready), roadmap{,-analysis,-quality}.json, audit-baseline.json,
# memory/, and the -<role>.md narratives (reviewer + LLM knowledge base).
# Ignoring by role suffix (never a bare *.json) fails safe: a new role at worst
# leaks one evidence file, whereas a broad *.json silently drops durable state.
.workflow/*-big-thinker.json
.workflow/*-feature-specialist.json
.workflow/*-senior-engineer.json
.workflow/*-ux-ui-specialist.json
.workflow/*-qa-senior.json
.workflow/*-validation-specialist.json
.workflow/*-documentation-specialist.json
.workflow/*-gatekeeper.json
.workflow/*-production-readiness.json
.workflow/*-merge-steward.json
.workflow/*.lock

# Built binaries (leading slash = root only, not cmd/centinela/ directory)
/centinela
/centinela-*

# Go test and benchmark artifacts
*.exe
*.test
*.out

# Dependency vendor directory (we use go modules)
vendor/

# Per-feature git worktrees (workflow.use_worktrees)
.worktrees/

# Playwright MCP scratch (page snapshots, console logs) + local screenshots
.playwright-mcp/
landing-*.png
landing-*.jpeg

# Local private notes — not committed
ECOSYSTEM.md

# Local governance telemetry — local-only in this repo (feature contract for other projects is git-tracked)
.workflow/telemetry/

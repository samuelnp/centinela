{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook postwrite"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook postwrite"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook prewrite",
            "statusMessage": "Validating workflow step..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook prewrite",
            "statusMessage": "Validating workflow step..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook session",
            "statusMessage": "Rehydrating session context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook autostart",
            "statusMessage": "Detecting new feature intent..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook orchestration",
            "statusMessage": "Enforcing subagent orchestration..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook plan-advisor",
            "statusMessage": "Advising during plan step..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook context",
            "statusMessage": "Checking workflow status..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook setup",
            "statusMessage": "Checking project setup..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook migrate",
            "statusMessage": "Checking managed migrations..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "centinela hook merge",
            "statusMessage": "Checking pending merges..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "centinela hook statusline"
  }
}
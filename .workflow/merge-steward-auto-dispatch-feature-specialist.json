  "edgeCases": [
    "Clean merge (no conflict, validate passes): Steward NOT dispatched, no pending marker, worktree removed, exit zero (parent regression guard)",
    "Text conflict: pending marker written with reason git-text-conflict + conflicted paths + worktree path; CENTINELA DIRECTIVE emitted naming prompt/feature/--continue; worktree kept; non-zero exit",
    "Post-merge validate failure: same dispatch path, marker reason post-merge-validate-failed",
    "Hook re-emits the directive on a subsequent prompt while marker exists and no valid steward evidence present",
    "Hook stops re-emitting once valid steward evidence exists",
    "Hook is silent when no pending marker exists",
    "--continue with valid APPLY + handoffTo complete + clean tree: finalizes, worktree removed, marker cleared, exit zero",
    "--continue with valid ESCALATE / handoffTo user: not finalized, worktree + marker kept, escalation note + proposed diff to stderr, non-zero exit",
    "--continue with missing steward evidence: actionable error, state unchanged, non-zero exit",
    "--continue with schema-invalid steward evidence: orchestration validator error surfaced, state unchanged, non-zero exit",
    "--continue with valid APPLY but dirty main tree: clean-tree re-check blocks finalize, worktree + marker kept, non-zero exit",
    "--continue with no pending marker: clear 'nothing to continue' error, no state change, non-zero exit",
    "Re-running merge while a pending marker exists: exactly one marker, rewritten with new reason (not appended), worktree kept"
  ],
  "handoffTo": "senior-engineer"
